# ============================================================
# SenseVoice 语音输入 - 配置模板
#
# 安装：
#   mkdir -p ~/.config/sensevoice-vibe
#   cp config/llm.env.example ~/.config/sensevoice-vibe/llm.env
#   # 然后填入下面的 <placeholder>
#
# 修改后必须重启服务才生效（环境变量在进程启动时固化）：
#   ./toggle_resident_f8.sh restart
#
# 也可以按 F8（脚本会自动检测此文件 mtime 比进程新，自动 restart）
# ============================================================

# === ASR 模型 ===
# 默认指向仓库内 ./models/sensevoice-small（由 download_models.sh 拉下）
SENSEVOICE_MODEL=./models/sensevoice-small
SENSEVOICE_LANGUAGE=auto
# ASR 推理后端：auto(自动) / onnx(强制 INT8) / pytorch(强制 FP32)
SENSEVOICE_ASR_BACKEND=auto

# === 注入模式 ===
# ibus: IBus commit_text（推荐，不占用剪贴板）
# clipboard: 剪贴板 + 模拟粘贴键（兼容模式）
SENSEVOICE_INJECT_MODE=ibus

# === VAD 参数 ===
SENSEVOICE_STREAM_ENDPOINT_MS=1500           # 静音多久判断你说完了（ms）
SENSEVOICE_STREAM_MAX_SEGMENT_MS=30000       # 单段最大时长，超过强制切（ms）
SENSEVOICE_STREAM_MIN_SEGMENT_MS=400         # 短于此则丢弃（ms）
SENSEVOICE_STREAM_VAD_AGGRESSIVENESS=2       # 0~3，越大越严格（越容易判静音）
SENSEVOICE_STREAM_START_MS=240
SENSEVOICE_STREAM_FRAME_MS=20
SENSEVOICE_STREAM_PRE_ROLL_MS=700            # 起点向前回看，避免吃字
SENSEVOICE_STREAM_INDICATOR=none

# === 声纹门禁（防止旁人说话被识别）===
SENSEVOICE_SPK_ENABLE=1
SENSEVOICE_SPK_THRESHOLD=0.60                # 相似度阈值，越高越严
SENSEVOICE_SPK_MIN_MS=900
SENSEVOICE_SPK_ENROLL_WAV=$HOME/.local/state/sensevoice-vibe/speaker_enroll.d
SENSEVOICE_SPK_MODEL=./models/eres2netv2     # 当前使用 ERes2NetV2，备选 ./models/campplus
SENSEVOICE_SPK_CACHE_DIR=./models/eres2netv2
SENSEVOICE_SPK_AGG=topk_mean
SENSEVOICE_SPK_TOPK=1
SENSEVOICE_SPK_ADAPTIVE=1                    # 自适应阈值
SENSEVOICE_SPK_PRUNE_OUTLIERS=1

# === 后处理 LLM（OpenAI 兼容 API）===
# 主链路：把 <YOUR_LLM_BASE_URL> 换成你的 LLM 服务地址（推荐内网 GPU 代理）
# 把 <YOUR_LLM_API_KEY> 换成 sk- 开头的 API key
SENSEVOICE_POST_LLM_ENABLE=1
SENSEVOICE_POST_LLM_BASE_URL=<YOUR_LLM_BASE_URL>
SENSEVOICE_POST_LLM_API_KEY=<YOUR_LLM_API_KEY>
SENSEVOICE_POST_LLM_MODEL=DeepSeek-V3.2
# 备选可填 GLM-5.1-FP8、Qwen2.5-72B-Instruct 等任何你的代理支持的 model id
# 用 curl <BASE_URL>/models 列出全部可用

# Fallback：主链路故障时切换的备用（建议填公网官方 API）
SENSEVOICE_POST_LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
SENSEVOICE_POST_LLM_FALLBACK_API_KEY=<YOUR_DEEPSEEK_OFFICIAL_KEY>
SENSEVOICE_POST_LLM_FALLBACK_MODEL=deepseek-chat

# 润色行为
SENSEVOICE_POST_LLM_MODE=polish_coding_aggressive   # 编程语境强润色
                                                    # 备选：polish_coding(保守)/polish(通用)
SENSEVOICE_POST_LLM_TIMEOUT_MS=1800
SENSEVOICE_POST_LLM_MAX_TOKENS=72
SENSEVOICE_POST_LLM_TEMPERATURE=0
SENSEVOICE_POST_LLM_MIN_CHARS=5
SENSEVOICE_POST_LLM_DYNAMIC_MAX_TOKENS=1
SENSEVOICE_POST_LLM_OUTPUT_TOKEN_FACTOR=0.7

# 熔断与缓存
SENSEVOICE_POST_LLM_CIRCUIT_MAX_FAILS=4
SENSEVOICE_POST_LLM_CIRCUIT_COOLDOWN_SEC=25
SENSEVOICE_POST_LLM_HARD_COOLDOWN_SEC=300
SENSEVOICE_POST_LLM_RETRY_ON_TIMEOUT=1
SENSEVOICE_POST_LLM_CACHE_TTL_SEC=300
SENSEVOICE_POST_LLM_CACHE_MAX_ENTRIES=120

# === 置信度路由（高置信度可跳过 LLM 调用）===
SENSEVOICE_CONF_ROUTE_ENABLE=1
SENSEVOICE_CONF_ROUTE_HIGH=0.42
SENSEVOICE_CONF_ROUTE_LOW=0.30

# === 输出控制 ===
SENSEVOICE_FILTER_FILLERS=1                  # 过滤"嗯/啊/呃"等填充词
SENSEVOICE_PARTIAL_STRATEGY=stable2
SENSEVOICE_EMIT_PARTIAL=0
SENSEVOICE_AUTO_ENTER=0                      # 是否自动按回车（聊天场景才开）

# === 项目术语表（自动从代码目录提取热词，提升专业术语识别）===
SENSEVOICE_PROJECT_LEXICON_ENABLE=1
SENSEVOICE_PROJECT_ROOT=$HOME                # 设为你常用的代码工作目录
SENSEVOICE_PROJECT_LEXICON_MAX_TERMS=2500
SENSEVOICE_PROJECT_LEXICON_HINT_LIMIT=16
SENSEVOICE_PROJECT_LEXICON_MIN_TERM_LEN=3

# === 日志 ===
SENSEVOICE_COMPARE_LOG_ENABLE=1
SENSEVOICE_COMPARE_LOG_KEEP_LINES=300
SENSEVOICE_DEBUG_INJECT=1
SENSEVOICE_RETENTION_KEEP_RECENT=20
SENSEVOICE_LOG_KEEP_LINES=120

# === 控制 ===
SENSEVOICE_SESSION_NOTIFY=0
SENSEVOICE_TOGGLE_DEBOUNCE_MS=450
