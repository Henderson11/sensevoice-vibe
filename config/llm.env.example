# ============================================================
# SenseVoice 语音输入 - 统一配置文件
# 所有配置集中在此文件，F8 快捷键和 toggle 脚本均从此读取
# 修改后需重启服务生效（F8 关再开，或 toggle_resident_f8.sh off && on）
# 安装: cp config/llm.env.example ~/.config/sensevoice-vibe/llm.env
# ============================================================

# === 模型 ===
# 使用仓库内模型（推荐），或指定外部路径
SENSEVOICE_MODEL=./models/sensevoice-small
SENSEVOICE_LANGUAGE=auto

# === 注入模式 ===
# ibus: IBus commit_text（推荐，不占用剪贴板）
# clipboard: 剪贴板 + 模拟粘贴键（兼容模式）
SENSEVOICE_INJECT_MODE=ibus

# === VAD 参数 ===
SENSEVOICE_STREAM_ENDPOINT_MS=900
SENSEVOICE_STREAM_MAX_SEGMENT_MS=20000
SENSEVOICE_STREAM_MIN_SEGMENT_MS=850
SENSEVOICE_STREAM_VAD_AGGRESSIVENESS=3
SENSEVOICE_STREAM_START_MS=240
SENSEVOICE_STREAM_FRAME_MS=20
SENSEVOICE_STREAM_PRE_ROLL_MS=700
SENSEVOICE_STREAM_PARTIAL_INTERVAL_MS=280
SENSEVOICE_STREAM_MIN_PARTIAL_MS=1300
SENSEVOICE_STREAM_INDICATOR=none

# === 声纹门禁 ===
SENSEVOICE_SPK_ENABLE=1
SENSEVOICE_SPK_THRESHOLD=0.45
SENSEVOICE_SPK_MIN_MS=900
SENSEVOICE_SPK_ENROLL_WAV=$HOME/.local/state/sensevoice-vibe/speaker_enroll.d
SENSEVOICE_SPK_MODEL=./models/spkrec-ecapa
SENSEVOICE_SPK_CACHE_DIR=./models/spkrec-ecapa
SENSEVOICE_SPK_AGG=topk_mean
SENSEVOICE_SPK_TOPK=1

# === 后处理 LLM ===
SENSEVOICE_POST_LLM_ENABLE=1
SENSEVOICE_POST_LLM_BASE_URL=http://your-api-host/v1
SENSEVOICE_POST_LLM_API_KEY=sk-your-api-key
SENSEVOICE_POST_LLM_MODEL=DeepSeek-V3.2
SENSEVOICE_POST_LLM_FALLBACK_MODEL=DeepSeek-V3.1-Terminus
SENSEVOICE_POST_LLM_MODE=polish_coding_aggressive
SENSEVOICE_POST_LLM_TIMEOUT_MS=1800
SENSEVOICE_POST_LLM_STRICT=0
SENSEVOICE_POST_LLM_MAX_TOKENS=72
SENSEVOICE_POST_LLM_TEMPERATURE=0

# === 置信度路由 ===
SENSEVOICE_CONF_ROUTE_ENABLE=1
SENSEVOICE_CONF_ROUTE_HIGH=0.42
SENSEVOICE_CONF_ROUTE_LOW=0.30

# === 输出控制 ===
SENSEVOICE_FILTER_FILLERS=1
SENSEVOICE_EMIT_PARTIAL=0
SENSEVOICE_AUTO_ENTER=0

# === 项目术语表 ===
SENSEVOICE_PROJECT_LEXICON_ENABLE=1
# 项目根目录（用于自动提取术语表，设为你的代码工作目录）
SENSEVOICE_PROJECT_ROOT=$HOME

# === 自学习纠错 ===
SENSEVOICE_LEARN_ENABLE=1

# === 日志 ===
SENSEVOICE_COMPARE_LOG_ENABLE=1
SENSEVOICE_DEBUG_INJECT=1

# === 控制 ===
SENSEVOICE_SESSION_NOTIFY=0
SENSEVOICE_TOGGLE_DEBOUNCE_MS=450
